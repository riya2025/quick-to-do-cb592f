{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "quick-to-do-api"
      }
    }
  ],
  "services": {
    "quick-to-do-api": {
      "root": ".",
      "framework": "vite"
    }
  }
}
